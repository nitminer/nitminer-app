# Redis Configuration Template
# Copy this to .env.local and customize for your environment

# ============================================
# REDIS CONFIGURATION
# ============================================

# Enable/Disable Redis optimization
REDIS_ENABLED=true

# Redis Connection Method 1: Direct host/port (for local development)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=  # Only set if your Redis requires password

# Redis Connection Method 2: Connection URL (for cloud services)
# Uncomment below and comment out the host/port above for cloud Redis
# REDIS_URL=redis://:password@redis-cloud-host.com:6379/0

# ============================================
# NEXT.JS CONFIGURATION
# ============================================

NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:7070

# ============================================
# DATABASE CONFIGURATION
# ============================================

MONGODB_URI=mongodb://localhost:27017/nitminer
# Or for MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nitminer?retryWrites=true&w=majority

# ============================================
# AUTHENTICATION
# ============================================

JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
NEXTAUTH_SECRET=your-nextauth-secret-change-this-in-production
NEXTAUTH_URL=http://localhost:7070

# ============================================
# CLERK AUTHENTICATION (Optional)
# ============================================

# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...

# ============================================
# SOCKET.IO CONFIGURATION
# ============================================

SOCKET_IO_PORT=7070

# ============================================
# EMAIL CONFIGURATION (For notifications)
# ============================================

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@nitminer.com

# ============================================
# PAYMENT GATEWAY (Razorpay)
# ============================================

# RAZORPAY_KEY_ID=your_key_id
# RAZORPAY_KEY_SECRET=your_key_secret

# ============================================
# FILE UPLOAD (Cloudinary)
# ============================================

# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# GOOGLE OAUTH (Optional)
# ============================================

# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# GOOGLE_CALLBACK_URL=http://localhost:7070/api/auth/google/callback

# ============================================
# EXTERNAL APIs
# ============================================

# Quotation service (if applicable)
# QUOTATION_API_URL=https://api.quotation.com
# QUOTATION_API_KEY=your_api_key

# ============================================
# LOGGING & MONITORING
# ============================================

LOG_LEVEL=debug
# SENTRY_DSN=  # For error tracking
# DATADOG_API_KEY=  # For monitoring

# ============================================
# FEATURE FLAGS
# ============================================

REDIS_ENABLED=true
SOCKET_IO_REDIS_ADAPTER=true
RATE_LIMITING_ENABLED=true
CACHE_ENABLED=true

# ============================================
# PERFORMANCE TUNING
# ============================================

# Connection timeouts (milliseconds)
REDIS_TIMEOUT=10000
DB_TIMEOUT=30000

# Cache TTLs (seconds)
USER_CACHE_TTL=3600
SESSION_CACHE_TTL=86400
PROFILE_CACHE_TTL=1800
CHAT_CACHE_TTL=3600

# Rate limiting
API_RATE_LIMIT_WINDOW=60000
API_RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_WINDOW=900000
AUTH_RATE_LIMIT_MAX=5
CHAT_RATE_LIMIT_WINDOW=60000
CHAT_RATE_LIMIT_MAX=30

# ============================================
# NOTES
# ============================================
#
# Development Setup:
# 1. Install Redis: brew install redis (macOS) or apt-get install redis-server (Linux)
# 2. Start Redis: redis-server or docker run -d -p 6379:6379 redis:7-alpine
# 3. Set REDIS_HOST=localhost, REDIS_PORT=6379
#
# Production Setup:
# 1. Use Redis Cloud or AWS ElastiCache
# 2. Set REDIS_URL with your cloud connection string
# 3. Enable SSL/TLS by using rediss:// protocol in URL
#
# Security Tips:
# 1. ALWAYS change JWT_SECRET and NEXTAUTH_SECRET in production
# 2. Use strong PASSWORD for Redis in production
# 3. Never commit real secrets to version control
# 4. Use secret management service (AWS Secrets Manager, etc.)
# 5. Enable Redis ACL for fine-grained access control
#
# Monitoring:
# 1. Check Redis health: curl http://localhost:7070/api/health/redis
# 2. Monitor connections: redis-cli CLIENT LIST
# 3. Check memory: redis-cli INFO memory
# 4. View commands: redis-cli MONITOR
#
